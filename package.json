{
  "name": "brisk",
  "private": true,
  "version": "0.3.0",
  "description": "Drop a folder, get a site. An open-source internal hosting platform with a zero-config backend API.",
  "license": "MIT",
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @usebrisk/worker dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,js,css,html,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,js,css,html,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "^7.28.0"
    }
  }
}
