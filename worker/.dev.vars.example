# Copy to .dev.vars for local development with `wrangler dev`.
# wrangler.jsonc carries no instance config, so this file is where local runs
# get their vars and secrets. Unset means the safe defaults: path-only,
# no-auth, private — enough to build sites locally without anything below.

# Flip on real auth / public mode to exercise that behavior locally:
# AUTH=google
# VISIBILITY=public
# DEPLOY_HISTORY=on                # keep every deploy (version history + rollback); unset = delete previous, bounded storage
# BASE_HOST=                       # leave empty for /s/<site>/ URLs locally
# ALLOWED_EMAILS=                  # exact emails, comma-separated
# ALLOWED_EMAIL_DOMAINS=           # whole domains, comma-separated
# SESSION_SECRET=dev-secret
# DEPLOY_TOKEN=dev-token           # then: BRISK_TOKEN=dev-token brisk deploy …
# GOOGLE_CLIENT_ID=                # only for testing the real browser login
# GOOGLE_CLIENT_SECRET=

# Optional AI providers:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
